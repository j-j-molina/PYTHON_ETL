  "split": {
    "type": "temporal",
    "date_col": "fecha_prestamo",
    "train_cutoff": "2025-09",
    "description": "Entrenar hasta sep-2025 inclusive. Evaluar desde oct-2025 en adelante."
  },
  "training": {
    "cv_folds": 5,
    "cv_scoring": "recall",
    "threshold_strategy": "recall",
    "threshold_min_precision": 0.06,
    "_threshold_strategy_note": "recall: maximiza recall con precision >= threshold_min_precision (0.06 > tasa base ~4.8%). Objetivo: capturar el mayor % posible de clientes que entrarán en mora.",
    "learning_curve_config": {
      "n_splits": 30,
      "test_size": 0.2,
      "_note": "Parámetros para ShuffleSplit en learning curves de model_training.py y heuristic_model.py."
    },
    "heuristic_cv_splits": 10,
    "selection_weights": {
      "roc_auc": 0.2,
      "pr_auc": 0.2,
      "recall": 0.5,
      "gap": 0.1
    },
    "_selection_weights_note": "Recall con peso 0.5: FN=crédito otorgado a quien no pagará=pérdida directa. Gap penaliza sobreajuste al train.",
    "models": [
      {
        "name": "Logistic Regression",
        "type": "logistic_regression",
        "params": {
          "class_weight": "balanced",
          "max_iter": 2000,
          "C": 1.0,
          "solver": "lbfgs",
          "random_state": 42
        }
      },
      {
        "name": "Decision Tree",
        "type": "decision_tree",
        "params": {
          "class_weight": "balanced",
          "max_depth": 4,
          "min_samples_leaf": 30,
          "random_state": 42
        }
      },
      {
        "name": "Random Forest",
        "type": "random_forest",
        "params": {
          "class_weight": "balanced_subsample",
          "n_estimators": 400,
          "max_depth": 6,
          "min_samples_leaf": 15,
          "max_features": "sqrt",
          "n_jobs": -1,
          "random_state": 42
        }
      },
      {
        "name": "HistGradient Boosting",
        "type": "hist_gradient_boosting",
        "params": {
          "max_iter": 400,
          "max_depth": 5,
          "min_samples_leaf": 20,
          "learning_rate": 0.03,
          "l2_regularization": 1.0,
          "class_weight": "balanced",
          "random_state": 42
        }
      },
      {
        "name": "Gradient Boosting",
        "type": "gradient_boosting",
        "params": {
          "n_estimators": 300,
          "learning_rate": 0.03,
          "max_depth": 3,
          "min_samples_leaf": 15,
          "subsample": 0.7,
          "random_state": 42
        },
        "fit_strategy": "sample_weight_positive"
      }
    ],
    "_models_note": "Catálogo de modelos configurable por use_case o globalmente. Cada item requiere {name, type, params}; fit_strategy opcional."
  },
  "monitoring": {
    "psi_threshold": 0.2,
    "psi_thresholds": {
      "stable": 0.10,
      "monitor": 0.20,
      "_note": "PSI < stable → Estable | stable <= PSI < monitor → Monitorear | PSI >= monitor → Drift"
    },
    "psi_n_bins": 10,
    "min_rows": 200
  },
  "logging": {
    "level": "INFO",
    "_note": "Valores válidos: DEBUG, INFO, WARNING, ERROR, CRITICAL. Puede sobreescribirse con env var LOG_LEVEL."
  },
  "deploy": {
    "host": "127.0.0.1",
    "port": 5000,
    "docker_image": "cdp_credito-scoring",
    "docker_port": 5000,
    "api_version": "v1",
    "risk_thresholds": {
      "_note": "Fracciones del threshold calibrado: score < bajo → Bajo, < threshold → Medio, >= threshold → Alto",
      "bajo": 0.5,
      "medio": 1.0
    },
    "batch_max_records": 10000
  },
  "_comment_feature_engineering": "Sección global usada como fallback. Cada use_case debe definir su propio 'feature_engineering' en use_cases.<nombre>. resolve_cfg() fusiona global + use_case (use_case gana en conflicto)."
}